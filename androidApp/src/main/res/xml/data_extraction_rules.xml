<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup rules for Android 12+ (targetSdk 31+).
  This is a local-first app: the SQLite database (expensetracker.db) and preferences
  (expensetracker_prefs) ARE the user's data, and OS auto-backup is an intentional feature
  (see README "Backup"). Empty cloud-backup / device-transfer sections mean "back up all app
  data" — declared explicitly to document intent and satisfy lint. Cloud backups are encrypted
  with the user's device credentials; nothing is uploaded to any app-controlled server.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Include all app data in the user's encrypted Google cloud backup. -->
    </cloud-backup>
    <device-transfer>
        <!-- Include all app data during device-to-device transfer. -->
    </device-transfer>
</data-extraction-rules>
