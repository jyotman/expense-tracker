CREATE TABLE captured_notification (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    notifKey TEXT,
    packageName TEXT NOT NULL,
    appLabel TEXT NOT NULL,
    title TEXT NOT NULL,
    text TEXT NOT NULL,
    amountMinor INTEGER,
    merchant TEXT,
    postedAt INTEGER NOT NULL,
    isRead INTEGER NOT NULL DEFAULT 0,
    expenseId INTEGER,
    -- Raw currency token extracted from the notification text ("S$", "SGD", "₹", etc.); NULL when
    -- no currency marker was detected. Shown as-is in the inbox — never assumed to be home currency.
    detectedCurrencyToken TEXT
);

CREATE INDEX captured_postedAt ON captured_notification(postedAt);
-- findDuplicate filters on notifKey on the capture hot path; keep it indexed.
CREATE INDEX captured_notifKey ON captured_notification(notifKey);

insert:
INSERT INTO captured_notification (notifKey, packageName, appLabel, title, text, amountMinor, merchant, postedAt, isRead, expenseId, detectedCurrencyToken)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, 0, NULL, ?);

selectAll:
SELECT * FROM captured_notification
ORDER BY postedAt DESC, id DESC;

selectById:
SELECT * FROM captured_notification WHERE id = ?;

-- Dedupe guard: same notification slot + same amount already recorded.
findDuplicate:
SELECT * FROM captured_notification
WHERE notifKey = :notifKey AND amountMinor IS :amountMinor
ORDER BY id DESC LIMIT 1;

unreadCount:
SELECT count(*) FROM captured_notification WHERE isRead = 0;

markRead:
UPDATE captured_notification SET isRead = 1 WHERE id = ?;

markAllRead:
UPDATE captured_notification SET isRead = 1;

setExpense:
UPDATE captured_notification SET expenseId = ?, isRead = 1 WHERE id = ?;

clearExpenseLink:
UPDATE captured_notification SET expenseId = NULL WHERE expenseId = ?;

lastInsertedId:
SELECT last_insert_rowid();

-- Prune already-handled (read) notifications older than a cutoff so the table can't grow forever.
deleteReadBefore:
DELETE FROM captured_notification
WHERE isRead = 1 AND postedAt < :cutoff;

deleteAll:
DELETE FROM captured_notification;
